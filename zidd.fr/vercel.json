{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/__data.json",
      "destination": "/_data/index.json"
    },
    {
      "source": "/:project/__data.json",
      "destination": "/_data/:project.json"
    },
    {
      "source": "/((?!_app/|_data/|.*\\..*).*)",
      "destination": "/"
    }
  ]
}