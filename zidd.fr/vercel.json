{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/__data.json",
      "destination": "/_data/index.json"
    },
    {
      "source": "/(?<project>.+)/__data.json",
      "destination": "/_data/$project.json"
    }
  ],
  "redirects": [
    {
      "source": "/(?<path>(?!_app/|_data/|research|studio|.*\\..*).*)",
      "destination": "/",
      "permanent": false
    }
  ]
}